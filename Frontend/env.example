# Copy this file to ".env" in this folder (Expo reads ".env", not "env.example").
EXPO_PUBLIC_API_PORT=5000

# --- USB + physical phone + `npx expo start --localhost` (recommended for your setup) ---
# 1) In a terminal (device connected): adb reverse tcp:5000 tcp:5000
# 2) Use the two lines below in .env:
EXPO_PUBLIC_ADB_REVERSE=1

# --- Same Wi‑Fi as PC (use `npx expo start --lan` instead of --localhost) ---
# EXPO_PUBLIC_ADB_REVERSE=0
# EXPO_PUBLIC_API_URL=http://192.168.x.x:5000

# --- Manual loopback URL (only if you also set trust; adb reverse still required) ---
# EXPO_PUBLIC_TRUST_LOOPBACK_API=1
# EXPO_PUBLIC_API_URL=http://127.0.0.1:5000

